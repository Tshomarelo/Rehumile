# Copy this file to .env and fill in your values

# Django
DEBUG=False
IMS_SECRET_KEY=your-secret-key-here-change-this
ALLOWED_HOSTS=yourusername.pythonanywhere.com,rehumile.co.za

# Database — MySQL on PythonAnywhere
DATABASE_URL=mysql://ims_user:yourpassword@yourusername.mysql.pythonanywhere-services.com/yourusername$rehumile_ims

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256

# CORS
CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com

# Storage
USE_S3=False
