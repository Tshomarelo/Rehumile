modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "IMS Portal"

[[workflows.workflow]]
name = "IMS Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/artifacts/ims-portal && DJANGO_SETTINGS_MODULE=config.settings PORT=8000 python manage.py migrate --noinput && python manage.py seed_admin && python manage.py collectstatic --noinput --clear && DJANGO_SETTINGS_MODULE=config.settings gunicorn config.wsgi:application --bind 0.0.0.0:8000 --workers 2 --timeout 60"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 26039
externalPort = 3000

[userenv]

[userenv.shared]
DJANGO_SETTINGS_MODULE = "config.settings"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]
